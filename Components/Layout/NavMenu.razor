@inject NavigationManager _navigationManager
@rendermode InteractiveServer

<nav class="navbar navbar-expand-lg bg-body-tertiary">
    
    <div class="container justify-content-start">
        <a class="navbar-brand" href="/home">
            <img src="images/labworksLogo.png" alt="HealthMe Logo" width="30" height="30" />
            HealthMe Labworks
        </a>
    </div>
    
    <div class="container justify-content-center">
        <ul class="navbar-nav">
            <li class="nav-item">
                <NavLink class="nav-link" aria-current="page" href="/home">Dashboard</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" aria-current="page" href="/patients">Patients</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" aria-current="page" href="/inventory">Inventory</NavLink>
            </li>
        </ul>
    </div>

    <div class="container justify-content-end">
        <button type="button" id="components-logout-button" class="btn btn-outline-danger" @onclick="logoutFunc">Logout</button>
    </div>
</nav>

@code {

    private void logoutFunc()
    {
        _navigationManager.NavigateTo("/");
    }

}
